# Copy this file to .env and fill in your values
# Never commit .env to git

# PostgreSQL connection string from Supabase
# Found in: Supabase Dashboard > Project Settings > Database > Connection string (URI)
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# JWT secret - generate a long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your-very-long-random-secret-here

# JWT expiry - how long login tokens last
JWT_EXPIRES_IN=7d

# Web Push VAPID keys - generate once with: node -e "const wp = require('web-push'); const keys = wp.generateVAPIDKeys(); console.log(keys)"
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_EMAIL=mailto:your@email.com

# Server port (Render sets this automatically)
PORT=3000

# Your frontend URL (for CORS) - e.g. https://yourname.github.io or http://localhost:8080
FRONTEND_URL=http://localhost:8080
